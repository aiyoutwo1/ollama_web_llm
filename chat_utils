import ollama
import json


def get_res(prompt):
    '''

    :param prompt: 提示词,你要问AI的问题
    :return: AI的回答
    ollama包的作用是:调用ollama中下载的模型接口.
    '''
    res = ollama.chat(model='deepseek-r1:1.5b', messages=[{  # ollama.chat() 和模型对话 返回模型回答
        'role': 'user',
        'content': prompt  # ollama.chat 调用ollama.chat的接口
    }])
    return res.message.content  # 变量res是ollama类型 返回大量的相关数据 我们只要里面的.message.content


